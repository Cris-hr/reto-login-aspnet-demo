@{
    ViewData["Title"] = "Bienvenida";
}

<div class="inicio-wrapper">
    <div class="card shadow text-center border-0 auth-card">

        <div class="mb-3 auth-icon">
            🚀
        </div>

        <h3 class="fw-bold mb-3">¡Bienvenida, July!</h3>

        <p class="text-muted mb-1">
            Su cuenta en el aplicativo X está activada.
        </p>

        <p class="text-muted mb-4">
            Ya puede iniciar sesión.
        </p>

        <a asp-controller="Auth"
           asp-action="Login"
           class="btn btn-primary w-100 py-2">
            Iniciar sesión
        </a>

    </div>
</div>